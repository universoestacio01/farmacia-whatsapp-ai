generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum ConversationState {
  IDLE
  WAITING_MEDICINE_NAME
  WAITING_RETAIL_BRAND
  WAITING_PRESENTATION
  WAITING_QUANTITY
  WAITING_CEP
  WAITING_ADDRESS_NUMBER
  WAITING_ADDRESS_COMPLEMENT
  WAITING_CONFIRMATION
  WAITING_PIX
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageRole {
  CUSTOMER
  ASSISTANT
  SYSTEM
}

enum MessageStatus {
  RECEIVED
  SENT
  FAILED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PENDING_PAYMENT_MANUAL
  PAID
  CANCELLED
  DELIVERED
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
  CANCELLED
}

enum PaymentMethod {
  PIX
}

model Customer {
  id             String         @id @default(cuid())
  whatsappNumber String         @unique @map("whatsapp_number")
  name           String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  addresses      Address[]
  conversations  Conversation[]
  orders         Order[]

  @@map("customers")
}

model Address {
  id           String   @id @default(cuid())
  customerId   String   @map("customer_id")
  cep          String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("addresses")
}

model Conversation {
  id                   String             @id @default(cuid())
  customerId           String             @map("customer_id")
  whatsappChatId       String?            @map("whatsapp_chat_id")
  status               ConversationStatus @default(OPEN)
  lastIntent           String?            @map("last_intent")
  pendingAction        ConversationState  @default(IDLE) @map("pending_action")
  lastMedicine         String?            @map("last_medicine")
  currentMedicineQuery String?            @map("current_medicine_query")
  currentRetailCategory String?           @map("current_retail_category")
  selectedPresentation Json?              @map("selected_presentation")
  candidateOptions     Json?              @map("candidate_options")
  cart                 Json?
  pendingAddress       Json?              @map("pending_address")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  customer             Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages             Message[]

  @@index([customerId])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String           @id @default(cuid())
  conversationId String           @map("conversation_id")
  whatsappId     String?          @unique @map("whatsapp_id")
  direction      MessageDirection
  role           MessageRole
  status         MessageStatus    @default(RECEIVED)
  content        String           @db.Text
  rawPayload     Json?            @map("raw_payload")
  createdAt      DateTime         @default(now()) @map("created_at")
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model Order {
  id         String      @id @default(cuid())
  customerId String      @map("customer_id")
  status     OrderStatus @default(DRAFT)
  totalCents Int         @default(0) @map("total_cents")
  notes      String?     @db.Text
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  payments   Payment[]

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model Payment {
  id                    String        @id @default(cuid())
  orderId               String        @map("order_id")
  method                PaymentMethod @default(PIX)
  status                PaymentStatus @default(PENDING)
  amountCents           Int           @map("amount_cents")
  amount                Decimal       @default(0) @db.Decimal(10, 2)
  provider              String?       @default("manual")
  providerPaymentId     String?       @map("provider_payment_id")
  providerTransactionId String?       @unique @map("provider_transaction_id")
  pixPayload            String?       @map("pix_payload") @db.Text
  pixCopyPaste          String?       @map("pix_copy_paste") @db.Text
  pixQrCode             String?       @map("pix_qr_code") @db.Text
  paymentUrl            String?       @map("payment_url")
  expiresAt             DateTime?     @map("expires_at")
  paidAt                DateTime?     @map("paid_at")
  rawResponse           Json?         @map("raw_response")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  order                 Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([status])
  @@index([provider])
  @@map("payments")
}
