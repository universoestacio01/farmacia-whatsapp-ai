generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageRole {
  CUSTOMER
  ASSISTANT
  SYSTEM
}

enum MessageStatus {
  RECEIVED
  SENT
  FAILED
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  CANCELLED
  DELIVERED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum PaymentMethod {
  PIX
}

model Customer {
  id             String         @id @default(cuid())
  whatsappNumber String         @unique @map("whatsapp_number")
  name           String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  addresses      Address[]
  conversations  Conversation[]
  orders         Order[]

  @@map("customers")
}

model Address {
  id           String   @id @default(cuid())
  customerId   String   @map("customer_id")
  cep          String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("addresses")
}

model Conversation {
  id             String             @id @default(cuid())
  customerId     String             @map("customer_id")
  whatsappChatId String?            @map("whatsapp_chat_id")
  status         ConversationStatus @default(OPEN)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  customer       Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([customerId])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String           @id @default(cuid())
  conversationId String           @map("conversation_id")
  whatsappId     String?          @unique @map("whatsapp_id")
  direction      MessageDirection
  role           MessageRole
  status         MessageStatus    @default(RECEIVED)
  content        String           @db.Text
  rawPayload     Json?            @map("raw_payload")
  createdAt      DateTime         @default(now()) @map("created_at")
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model Order {
  id         String      @id @default(cuid())
  customerId String      @map("customer_id")
  status     OrderStatus @default(DRAFT)
  totalCents Int         @default(0) @map("total_cents")
  notes      String?     @db.Text
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  payments   Payment[]

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String        @map("order_id")
  method            PaymentMethod @default(PIX)
  status            PaymentStatus @default(PENDING)
  amountCents       Int           @map("amount_cents")
  provider          String?
  providerPaymentId String?       @map("provider_payment_id")
  pixPayload        String?       @map("pix_payload") @db.Text
  expiresAt         DateTime?     @map("expires_at")
  paidAt            DateTime?     @map("paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([status])
  @@map("payments")
}
